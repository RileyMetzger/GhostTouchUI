<Window x:Class="GhostTouchUi.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModel="clr-namespace:GhostTouchUi.ViewModel"
        mc:Ignorable="d"
        
        Title="GTUI"
        Height="400" 
        MaxHeight="400" 
        MinHeight="400"
        Width="250"  
        MaxWidth="250"
        MinWidth="250"
        Background="{StaticResource BgColorSecondaryBrush}">
    
    <Window.DataContext>
        <viewModel:MainWindowViewModel/>
    </Window.DataContext>

    <Grid>

        

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="150"/>
        </Grid.RowDefinitions>

        <Button Style="{StaticResource NoMouseOverButtonStyle}"
                Command="{Binding ToggleAnimationCommand}" 
                x:Name="GhostButton">

            <Button.Content>
                <Image Source="{Binding CurrentGhostIcon}" Stretch="Uniform" />
            </Button.Content>
            
        </Button>

        <ListView Grid.Row="1"
                  Padding="2,5"
                  Background="{StaticResource BgColorPrimaryBrush}"
                  ItemsSource="{Binding Logs}"
                  HorizontalContentAlignment="Stretch"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  x:Name="GhostLogListView">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" 
                                Margin="5 0" 
                                MinHeight="15" >

                        <TextBlock Text="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}"
                                   FontFamily="{StaticResource ArcadeFont}"
                                   FontSize="9"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,0,10,0"
                                   VerticalAlignment="Center"/>

                        <TextBlock Text="{Binding Message}"
                                   FontFamily="{StaticResource ArcadeFont}"
                                   FontSize="8"
                                   TextWrapping="WrapWithOverflow"
                                   VerticalAlignment="Center"
                                   MaxWidth="130"
                                   LineHeight="8">

                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsActivationEvent}" Value="True">
                                            <Setter Property="Foreground" Value="{StaticResource TextAlertBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>

                        </TextBlock>

                        

                    </StackPanel>
                </DataTemplate>


            </ListView.ItemTemplate>
        </ListView>
       

    </Grid>
</Window>
