<Application x:Class="GhostTouchUi.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:tb="http://www.hardcodet.net/taskbar"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <FontFamily x:Key="ArcadeFont">/GhostMouseUi;component/Assets/Fonts/#Press Start 2P</FontFamily>

        <Color x:Key="UiBackgroundPrimary">#383838</Color>
        <Color x:Key="UiBackgroundSecondary">#2c2c2c</Color>
        <Color x:Key="UiTextWhite">#d2d2d2</Color>
        <Color x:Key="UiTextRed">#ec0b43</Color>

        <SolidColorBrush x:Key="BgColorPrimaryBrush" Color="{StaticResource UiBackgroundPrimary}"/>
        <SolidColorBrush x:Key="BgColorSecondaryBrush" Color="{StaticResource UiBackgroundSecondary}"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource UiTextWhite}"/>
        <SolidColorBrush x:Key="TextAlertBrush" Color="{StaticResource UiTextRed}"/>

        <Style x:Key="NoMouseOverButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

        </Style>

        <tb:TaskbarIcon x:Key="AppNotifyIcon"
                        ToolTipText="Ghost Touch UI"
                        IconSource="/Assets/Icons/Chibi_ghost_white.ico"
                        Visibility="Visible">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Restore" Click="Restore_OnClick"/>
                    <MenuItem Header="Exit" Click="Exit_OnClick"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>

    </Application.Resources>
</Application>
